# ====== Server settings ======
HOST=127.0.0.1
PORT=8080
SERVER_WORKERS=4
ENVIRONMENT=development
# Server Configuration
SERVER_HOST=127.0.0.1
SERVER_PORT=8080

# ====== Database settings ======
# Database Configuration
DATABASE_URL=postgres://${DB_USERNAME}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_INITIAL_DATABASE}
DB_HOST=100.64.1.10
DB_PORT=5432
DB_INITIAL_DATABASE=parkingappdb
DB_USERNAME=postgres
DB_PASSWORD=parking2025
DB_MAX_CONNECTIONS=1
DB_CONNECTION_TIMEOUT=100
DB_IDLE_TIMEOUT=5
DB_POOL_TIMEOUT=30
DB_CONNECTION_POOL_SIZE=1

# ====== JWT settings ======
JWT_SECRET=1234567890abcdefghijklmnopqrstuvwxyz
JWT_REFRESH_SECRET=abcdefghijklmnopqrstuvwxyz1234567890
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=30
# JWT Configuration
JWT_EXPIRATION=24h

# ====== Logging settings ======
RUST_LOG=info
LOG_LEVEL=info
LOG_DIR=logs
APP_NAME=parking_app
ENABLE_FILE_LOGGING=true
ENABLE_CONSOLE_LOGGING=true

# ====== CORS configuration ======
ENABLE_CORS=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,Accept,Origin,X-Requested-With
CORS_MAX_AGE=3600
CORS_ALLOW_ORIGIN=*

# ====== Email settings ======
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM_ADDRESS=noreply@parkingapp.com
EMAIL_FROM_NAME="Parking App"

# ====== SMS settings ======
SMS_API_KEY=
SMS_API_SECRET=
SMS_FROM_NUMBER=

# ====== Application specific settings ======
API_TIMEOUT=30
ENABLE_SWAGGER=true
# 5MB in bytes
MAX_REQUEST_BODY_SIZE=5242880
FLUTTER_APP_BACKEND_URL=http://127.0.0.1:8080

# ====== Rate limiting settings ======
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_DURATION=60 # seconds

# ====== Security settings ======
# set to true in production
SECURE_COOKIES=false
# bcrypt cost factor
HASH_COST=10
PASSWORD_MIN_LENGTH=8

# ====== Development/debug settings ======
# set to false in production
DEBUG_MODE=true
PRINT_DB_QUERIES=false

# Application Settings
APP_NAME=Parking_App
LOG_LEVEL=debug

# Other Settings
RUST_BACKTRACE=1